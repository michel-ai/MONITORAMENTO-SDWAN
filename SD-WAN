tive;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  gap: 2px;\n  height: 16px;\n  min-width: 0;\n  padding: 0;\n  border: 0;\n  background: transparent;\n  cursor: pointer;\n}\n\n.ticket-indicator .ticket-badge-letter {\n  width: 16px;\n  height: 16px;\n  min-width: 16px;\n  font-size: 10px;\n  transition: transform .15s ease, filter .15s ease;\n}\n\n.ticket-indicator .ticket-count {\n  color: rgba(245,245,245,0.92);\n  font-size: 10px;\n  font-weight: 800;\n  line-height: 1;\n  text-shadow: none;\n}\n\n.ticket-indicator:hover .ticket-badge-letter {\n  transform: scale(1.13);\n  filter: brightness(1.12);\n}\n\n.ticket-indicator:hover .ticket-count {\n  color: #fff;\n}\n\n.ticket-indicator .ticket-tooltip {\n  position: absolute;\n  top: 22px;\n  right: 0;\n  z-index: 20;\n  display: none;\n  min-width: 210px;\n  max-width: 320px;\n  padding: 10px 12px;\n  border: 1px solid rgba(255,255,255,0.16);\n  border-radius: 9px;\n  background: rgba(10,10,10,0.96);\n  color: #f2f2f2;\n  font-size: 12px;\n  font-weight: 700;\n  line-height: 1.45;\n  letter-spacing: .01em;\n  text-align: left;\n  white-space: normal;\n  box-shadow:\n    0 10px 28px rgba(0,0,0,0.48),\n    inset 0 1px 0 rgba(255,255,255,0.06);\n}\n\n.ticket-indicator:hover .ticket-tooltip {\n  display: block;\n}\n\n.ticket-indicator .ticket-tooltip div + div {\n  margin-top: 4px;\n}\n\n.ticket-dot {\n  display: none;\n}\n\n/* =========================================================\n   MODAL\n========================================================= */\n\n.modal-overlay {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  background: transparent;\n  backdrop-filter: none;\n  -webkit-backdrop-filter: none;\n  display: none;\n  justify-content: center;\n  align-items: center;\n  z-index: 9999;\n}\n\n.modal-content {\n  position: relative;\n  width: 90%;\n  max-width: 500px;\n  padding: 20px;\n  border: 1px solid rgba(255,255,255,0.10);\n  border-radius: 12px;\n  background: rgba(18,18,18,0.90);\n  box-shadow: 0 18px 45px rgba(0,0,0,0.48);\n  animation: modal-in .3s ease-out;\n  backdrop-filter: blur(10px) saturate(105%);\n  -webkit-backdrop-filter: blur(10px) saturate(105%);\n}\n\n.modal-close {\n  position: absolute;\n  top: 15px;\n  right: 15px;\n  color: rgba(230,230,230,0.48);\n  cursor: pointer;\n  font-size: 24px;\n  line-height: 1;\n}\n\n.modal-close:hover { color: #fff; }\n\n.modal-header {\n  margin-bottom: 14px;\n  padding-bottom: 10px;\n  border-bottom: 1px solid rgba(255,255,255,0.07);\n}\n\n.modal-title {\n  padding-right: 28px;\n  color: #f2f2f2;\n  font-size: 18px;\n  font-weight: 800;\n  letter-spacing: .02em;\n}\n\n.modal-body {\n  display: flex;\n  flex-direction: column;\n  gap: 10px;\n}\n\n.modal-row {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n  padding: 10px 12px;\n  border: 1px solid rgba(255,255,255,0.055);\n  border-radius: 8px;\n  background: rgba(3,4,5,0.35);\n}\n\n.modal-label {\n  color: rgba(230,230,230,0.62);\n  font-size: 11px;\n  font-weight: 800;\n  letter-spacing: .03em;\n}\n\n.modal-value {\n  color: #f0f0f0;\n  font-size: 13px;\n  font-weight: 600;\n  line-height: 1.4;\n  white-space: pre-wrap;\n  word-break: break-word;\n}\n\n/* =========================================================\n   DRAWERS / SIDEBARS\n========================================================= */\n\n.tickets-drawer,\n.incidents-sidebar {\n  position: fixed;\n  top: 12px;\n  right: 12px;\n  bottom: 12px;\n  left: auto;\n  z-index: 9997;\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n  width: min(980px, 58vw);\n  height: auto;\n  border: 1px solid rgba(255,255,255,0.09);\n  border-radius: 14px;\n  background: rgba(18,18,18,0.90);\n  box-shadow: -8px 0 30px rgba(0,0,0,.42);\n  opacity: 0;\n  pointer-events: none;\n  transform: translateX(calc(100% + 20px));\n  transition: transform .28s ease, opacity .2s ease;\n  backdrop-filter: blur(10px) saturate(105%);\n  -webkit-backdrop-filter: blur(10px) saturate(105%);\n}\n\n.tickets-drawer.open,\n.incidents-sidebar.open {\n  opacity: 1;\n  pointer-events: auto;\n  transform: translateX(0);\n}\n\n.tickets-drawer-header,\n.incidents-sidebar-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 12px 14px;\n  border-bottom: 1px solid rgba(255,255,255,0.065);\n  background: rgba(255,255,255,0.025);\n}\n\n.tickets-drawer-title,\n.incidents-sidebar-title {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  color: #f2f2f2;\n  font-size: 13px;\n  font-weight: 800;\n  letter-spacing: .02em;\n}\n\n.sidebar-title-icon {\n  width: 18px;\n  height: 18px;\n  min-width: 18px;\n  font-size: 11px;\n  box-shadow:\n    inset 0 1px 0 rgba(255,255,255,0.20),\n    0 4px 10px rgba(0,0,0,0.28);\n}\n\n.tickets-drawer-actions,\n.incidents-sidebar-actions {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n}\n\n.tickets-count-label,\n.inc-section-count {\n  color: rgba(230,230,230,0.62);\n  font-size: 11px;\n  font-weight: 800;\n}\n\n.tickets-close,\n.incidents-close {\n  padding: 5px 10px;\n  border: 1px solid rgba(255,255,255,0.10);\n  border-radius: 6px;\n  background: rgba(255,255,255,0.045);\n  color: #e4e4e4;\n  cursor: pointer;\n  font-size: 11px;\n  font-weight: 800;\n}\n\n.tickets-close:hover,\n.incidents-close:hover {\n  border-color: rgba(255,255,255,0.20);\n}\n\n.tickets-drawer-body,\n.incidents-sidebar-body {\n  flex: 1;\n  min-height: 0;\n  overflow: auto;\n  padding: 12px;\n}\n\n.incidents-sidebar-body {\n  display: flex;\n  flex-direction: column;\n  gap: 14px;\n}\n\n.tickets-empty {\n  padding: 18px 10px;\n  color: rgba(220,220,220,0.48);\n  font-size: 12px;\n  font-weight: 800;\n  text-align: center;\n}\n\n/* =========================================================\n   TABELAS DOS CHAMADOS\n========================================================= */\n\n.tickets-table,\n.incidents-table {\n  width: 100%;\n  border-collapse: collapse;\n  table-layout: fixed;\n}\n\n.tickets-table th,\n.tickets-table td,\n.incidents-table th,\n.incidents-table td {\n  padding: 8px 10px;\n  border-bottom: 1px solid rgba(255,255,255,0.055);\n  color: #e4e4e4;\n  text-align: left;\n  vertical-align: top;\n  line-height: 1.45;\n  word-break: normal;\n  overflow-wrap: anywhere;\n}\n\n.tickets-table th,\n.incidents-table th {\n  position: sticky;\n  top: 0;\n  z-index: 1;\n  background: rgba(255,255,255,0.035);\n  color: rgba(235,235,235,0.88);\n  font-weight: 800;\n}\n\n.tickets-table th,\n.tickets-table td {\n  font-size: 13px;\n}\n\n.incidents-table {\n  min-width: 980px;\n}\n\n.incidents-table th,\n.incidents-table td {\n  font-size: 12px;\n  white-space: normal;\n}\n\n.tickets-table th:nth-child(1) { width: 7%; }\n.tickets-table th:nth-child(2) { width: 14%; }\n.tickets-table th:nth-child(3) { width: 14%; }\n.tickets-table th:nth-child(4) { width: 12%; }\n.tickets-table th:nth-child(5) { width: 14%; }\n.tickets-table th:nth-child(6) { width: 10%; }\n.tickets-table th:nth-child(7) { width: 7%; }\n.tickets-table th:nth-child(8),\n.tickets-table td:nth-child(8) {\n  width: 32%;\n  max-width: 32%;\n}\n\n.incidents-table th:nth-child(1), .incidents-table td:nth-child(1) { width: 190px; }\n.incidents-table th:nth-child(2), .incidents-table td:nth-child(2) { width: 85px; }\n.incidents-table th:nth-child(3), .incidents-table td:nth-child(3) { width: 95px; }\n.incidents-table th:nth-child(4), .incidents-table td:nth-child(4) { width: 270px; }\n.incidents-table th:nth-child(5), .incidents-table td:nth-child(5) { width: 100px; white-space: nowrap; }\n.incidents-table th:nth-child(6), .incidents-table td:nth-child(6),\n.incidents-table th:nth-child(7), .incidents-table td:nth-child(7) { width: 135px; white-space: nowrap; }\n\n.ticket-positioning-btn {\n  width: 100%;\n  padding: 0;\n  border: 0;\n  background: transparent;\n  color: #e4e4e4;\n  cursor: pointer;\n  font-size: 13px;\n  font-weight: 500;\n  text-align: left;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n\n.ticket-positioning-btn:hover {\n  color: #fff;\n}\n\n.jira-ticket-link,\n.grc-ticket-link,\n.inc-problem-link {\n  color: #e4e4e4;\n  text-decoration: none;\n  cursor: pointer;\n  font-weight: 800;\n}\n\n.jira-ticket-link:hover,\n.grc-ticket-link:hover,\n.inc-problem-link:hover {\n  color: #fff;\n  text-decoration: underline;\n}\n\n/* =========================================================\n   INCIDENTES ZABBIX\n========================================================= */\n\n.incidents-search {\n  width: 190px;\n  padding: 5px 8px;\n  border-radius: 6px;\n  background: rgba(8,8,8,0.48);\n  font-size: 11px;\n}\n\n.inc-section {\n  display: flex;\n  flex-direction: column;\n  min-height: 0;\n  overflow: hidden;\n  border: 1px solid rgba(255,255,255,0.055);\n  border-radius: 10px;\n  background: rgba(3,4,5,0.35);\n}\n\n.inc-section-open {\n  flex: 0 0 auto;\n  max-height: 45%;\n}\n\n.inc-section-history {\n  flex: 1 1 auto;\n  min-height: 220px;\n}\n\n.inc-section-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 10px 12px;\n  border-bottom: 1px solid rgba(255,255,255,0.065);\n  background: rgba(255,255,255,0.025);\n}\n\n.inc-section-title {\n  color: #f2f2f2;\n  font-size: 12px;\n  font-weight: 800;\n  letter-spacing: .02em;\n}\n\n.inc-table-wrap {\n  min-height: 0;\n  max-height: 42vh;\n  overflow: auto;\n  scrollbar-color: rgba(255,255,255,0.25) rgba(0,0,0,0.28);\n}\n\n.inc-section-open .inc-table-wrap {\n  max-height: 330px;\n}\n\n.inc-section-history .inc-table-wrap {\n  flex: 1 1 auto;\n  max-height: none;\n}\n\n.inc-status-open,\n.inc-sev-disaster { color: #ff6060 !important; font-weight: 800; }\n.inc-status-resolved { color: #31e27c !important; font-weight: 800; }\n.inc-sev-high { color: #ff866c !important; font-weight: 800; }\n.inc-sev-average { color: #d8b23f !important; font-weight: 800; }\n.inc-sev-warning { color: #f2b84b !important; font-weight: 800; }\n.inc-sev-info { color: #35b7f2 !important; font-weight: 800; }\n\n/* =========================================================\n   DESFOQUE DE FUNDO\n========================================================= */\n\n.top-alert-card.hidden {\n  opacity: 1 !important;\n  pointer-events: auto !important;\n  transform: none !important;\n}\n\n/* =========================================================\n   DESFOQUE ESTÁVEL PARA MODAL E SIDEBARS\n   Mantém a força visual anterior, sem quebrar a topbar\n========================================================= */\n\n.noc-root.drawer-open .topbar,\n.noc-root.drawer-open .noc-body,\n.noc-root.modal-open .topbar,\n.noc-root.modal-open .noc-body {\n  filter: none !important;\n  opacity: 1 !important;\n}\n\n.noc-root.drawer-open::before,\n.noc-root.modal-open::before {\n  content: \"\";\n  position: fixed;\n  inset: 0;\n  z-index: 9000;\n  pointer-events: none;\n\n  background: rgba(0, 0, 0, 0.28);\n  backdrop-filter: blur(3px) brightness(0.55);\n  -webkit-backdrop-filter: blur(3px) brightness(0.55);\n}\n\n.tickets-drawer,\n.incidents-sidebar {\n  z-index: 9100 !important;\n}\n\n.modal-overlay {\n  z-index: 9200 !important;\n}\n\n.modal-content {\n  position: relative;\n  z-index: 9201;\n}\n\n/* =========================================================\n   ANIMAÇÕES\n========================================================= */\n\n@keyframes card-in {\n  from { opacity: 0; transform: translateY(5px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n\n@keyframes modal-in {\n  from { transform: scale(0.9); opacity: 0; }\n  to { transform: scale(1); opacity: 1; }\n}\n\n\n/* =========================================================\n   MODO PERFORMANCE / FLUIDEZ\n   Reduz custo visual sem mudar layout\n========================================================= */\n\n.eq-card,\n.topbar,\n.top-m-card,\n.topbar-clock,\n.m-box,\n.offline-link-status,\n.modal-content,\n.tickets-drawer,\n.incidents-sidebar {\n  backdrop-filter: none !important;\n  -webkit-backdrop-filter: none !important;\n}\n\n.eq-card {\n  background: rgba(18, 18, 18, 0.42) !important;\n  box-shadow:\n    inset 0 1px 0 rgba(255,255,255,0.06),\n    0 8px 18px rgba(0,0,0,0.28) !important;\n}\n\n.eq-card:hover {\n  box-shadow:\n    inset 0 1px 0 rgba(255,255,255,0.08),\n    0 10px 22px rgba(0,0,0,0.32) !important;\n}\n\n.topbar {\n  background: rgba(18, 18, 18, 0.50) !important;\n  box-shadow:\n    inset 0 1px 0 rgba(255,255,255,0.06),\n    0 8px 20px rgba(0,0,0,0.30) !important;\n}\n\n.m-box,\n.offline-link-status {\n  background: rgba(4, 4, 4, 0.50) !important;\n  box-shadow:\n    inset 0 1px 0 rgba(255,255,255,0.03),\n    0 4px 10px rgba(0,0,0,0.18) !important;\n}\n\n.top-m-card,\n.topbar-clock {\n  background: rgba(18,18,18,0.50) !important;\n  box-shadow:\n    inset 0 1px 0 rgba(255,255,255,0.05),\n    0 6px 14px rgba(0,0,0,0.24) !important;\n}\n\n.eq-card,\n.top-m-card,\n.topbar-clock,\n.m-box,\n.offline-link-status {\n  will-change: auto;\n}\n\n\n/* =========================================================\n   REDUÇÃO DE ANIMAÇÕES PARA MAIS FLUIDEZ\n========================================================= */\n\n.eq-card {\n  animation: none !important;\n}\n\n.eq-card,\n.top-m-card,\n.ticket-indicator .ticket-badge-letter,\n.tickets-drawer,\n.incidents-sidebar {\n  transition-duration: .12s !important;\n}\n\n@keyframes card-in {\n  from {\n    opacity: 1;\n    transform: none;\n  }\n  to {\n    opacity: 1;\n    transform: none;\n  }\n}\n\n/* =========================================================\n   MODAL: DESFOQUE SEM QUEBRAR A TOPBAR\n========================================================= */\n\n.noc-root.modal-open .noc-body {\n  filter: blur(3px) brightness(0.55);\n  transition: filter .2s ease;\n}\n\n/* Mantém a topbar visível e estável quando o modal abre */\n.noc-root.modal-open .topbar {\n  filter: none !important;\n  opacity: 0.42;\n  transition: opacity .2s ease;\n}\n\n/* Evita que contadores/sele