untId, labelId, count) => {\n  const countEl = qs(countId);\n  const labelEl = qs(labelId);\n  if (countEl) countEl.innerText = count;\n  if (labelEl) labelEl.innerText = `${count} chamado(s)`;\n};\n\nconst renderizarDrawerChamadosGRC = () => {\n  const body = qs('#tickets-drawer-body');\n  if (!body) return;\n\n  atualizarContadorDrawer('#tickets-toggle-count', '#tickets-count-label', ticketsGRC.length);\n\n  if (!ticketsGRC.length) {\n    body.innerHTML = `<div class=\"tickets-empty\">Sem chamados abertos</div>`;\n    return;\n  }\n\n  body.innerHTML = `\n    <table class=\"tickets-table\">\n      <thead>\n        <tr>\n          <th>Ticket</th><th>Centro</th><th>Designação</th><th>Abertura</th>\n          <th>Atualização/Fechamento</th><th>Sintoma</th><th>Tipo</th><th>Posicionamento</th>\n        </tr>\n      </thead>\n      <tbody>\n        ${ticketsGRC.map((t, idx) => `\n          <tr>\n            <td>${montarUrlTicketGRC(t) ? `<a class=\"grc-ticket-link\" href=\"${escaparHtml(montarUrlTicketGRC(t))}\" target=\"_blank\" rel=\"noopener noreferrer\">${escaparHtml(t.ticket)}</a>` : escaparHtml(t.ticket)}</td>\n            <td>${escaparHtml(t.centro)}</td>\n            <td>${escaparHtml(t.designacao)}</td>\n            <td>${escaparHtml(t.abertura)}</td>\n            <td>${escaparHtml(t.atualizacao)}</td>\n            <td>${escaparHtml(t.sintoma)}</td>\n            <td>${escaparHtml(t.tipo)}</td>\n            <td><button type=\"button\" class=\"ticket-positioning-btn\" data-ticket-index=\"${idx}\" data-ticket-source=\"grc\" title=\"Clique para visualizar completo\">${escaparHtml(truncarTexto(t.posicionamento, 140))}</button></td>\n          </tr>\n        `).join('')}\n      </tbody>\n    </table>\n  `;\n};\n\nconst renderizarDrawerChamadosJira = () => {\n  const body = qs('#tickets-drawer-body-jira');\n  if (!body) return;\n\n  atualizarContadorDrawer('#tickets-toggle-count-jira', '#tickets-count-label-jira', ticketsJira.length);\n\n  if (!ticketsJira.length) {\n    body.innerHTML = `<div class=\"tickets-empty\">Sem chamados abertos</div>`;\n    return;\n  }\n\n  body.innerHTML = `\n    <table class=\"tickets-table\">\n      <thead>\n        <tr><th>Ticket</th><th>Centro</th><th>Abertura</th><th>Atualização/Fechamento</th><th>Tipo</th><th>Posicionamento</th></tr>\n      </thead>\n      <tbody>\n        ${ticketsJira.map((t, idx) => `\n          <tr>\n            <td>${montarUrlTicketJira(t) ? `<a class=\"jira-ticket-link\" href=\"${escaparHtml(montarUrlTicketJira(t))}\" target=\"_blank\" rel=\"noopener noreferrer\">${escaparHtml(t.ticket)}</a>` : escaparHtml(t.ticket)}</td>\n            <td>${escaparHtml(t.centro)}</td>\n            <td>${escaparHtml(t.abertura)}</td>\n            <td>${escaparHtml(t.atualizacao)}</td>\n            <td>${escaparHtml(t.tipo)}</td>\n            <td><button type=\"button\" class=\"ticket-positioning-btn\" data-ticket-index=\"${idx}\" data-ticket-source=\"jira\" title=\"Clique para visualizar completo\">${escaparHtml(truncarTexto(t.posicionamento, 140))}</button></td>\n          </tr>\n        `).join('')}\n      </tbody>\n    </table>\n  `;\n};\n\n/* =========================================================\n   VIEW DE INCIDENTES\n========================================================= */\n\nconst filtrarIncidentesPorBusca = (lista) => {\n  const termo = normalizarTexto(qs('#incidents-search')?.value || '');\n  if (!termo) return lista;\n  return lista.filter((inc) => normalizarTexto(inc.host || '').includes(termo));\n};\n\nconst renderizarIncidentes = (containerId, lista) => {\n  const el = qs(`#${containerId}`);\n  if (!el) return;\n\n  const filtrados = filtrarIncidentesPorBusca(lista);\n  const historico = containerId === 'inc-history-body';\n\n  if (!filtrados.length) {\n    el.innerHTML = `<div class=\"tickets-empty\">Sem incidentes</div>`;\n    return;\n  }\n\n  el.innerHTML = `\n    <table class=\"incidents-table\">\n      <thead>\n        <tr>\n          <th>Host</th><th>Sev.</th><th>Status</th><th>Problema</th><th>Age</th><th>Hora</th>\n          ${historico ? '<th>Hora Recuperação</th>' : ''}\n        </tr>\n      </thead>\n      <tbody>\n        ${filtrados.map((inc) => `\n          <tr>\n            <td>${escaparHtml(inc.host || 'N/D')}</td>\n            <td>${escaparHtml(inc.severity || 'N/D')}</td>\n            <td class=\"${String(inc.status).toUpperCase().includes('RESOLVED') ? 'inc-status-resolved' : 'inc-status-open'}\">${escaparHtml(inc.status || 'N/D')}</td>\n            <td>${montarUrlEventoZabbix(inc) ? `<a class=\"inc-problem-link\" href=\"${escaparHtml(montarUrlEventoZabbix(inc))}\" target=\"_blank\" rel=\"noopener noreferrer\">${escaparHtml(inc.problem || 'N/D')}</a>` : escaparHtml(inc.problem || 'N/D')}</td>\n            <td>${escaparHtml(inc.age || 'N/D')}</td>\n            <td>${escaparHtml(inc.time || 'N/D')}</td>\n            ${historico ? `<td>${escaparHtml(inc.recovery_time || 'N/D')}</td>` : ''}\n          </tr>\n        `).join('')}\n      </tbody>\n    </table>\n  `;\n};\n\nconst atualizarViewIncidentes = () => {\n  const atuais = filtrarIncidentesPorBusca(window.__nocIncidentesAtuais);\n  const historico = filtrarIncidentesPorBusca(window.__nocIncidentesHistorico);\n\n  renderizarIncidentes('inc-open-body', window.__nocIncidentesAtuais);\n  renderizarIncidentes('inc-history-body', window.__nocIncidentesHistorico);\n\n  const openCount = qs('#inc-open-count');\n  const historyCount = qs('#inc-history-count');\n  const zbxAlertCount = qs('#zabbix-alert-count');\n\n  if (openCount) openCount.innerText = atuais.length;\n  if (historyCount) historyCount.innerText = historico.length;\n\n  /*\n    O contador Z do topo deve mostrar o TOTAL de incidentes atuais,\n    não o total filtrado pela pesquisa da sidebar.\n  */\n  if (zbxAlertCount) zbxAlertCount.innerText = window.__nocIncidentesAtuais.length;\n};\n\nconst baixarCsvIncidentes = () => {\n  const atuais = filtrarIncidentesPorBusca(window.__nocIncidentesAtuais).map((inc) => ({ ...inc, grupo: 'Incidentes no momento' }));\n  const historico = filtrarIncidentesPorBusca(window.__nocIncidentesHistorico).map((inc) => ({ ...inc, grupo: 'Histórico de incidentes' }));\n  const rows = [...atuais, ...historico];\n  const headers = ['Grupo', 'Host', 'Severidade', 'Status', 'Problema', 'Age', 'Hora', 'Hora Recuperação'];\n  const csvEscape = (value) => `\"${String(value ?? '').replace(/\"/g, '\"\"')}\"`;\n\n  const csv = [\n    headers.map(csvEscape).join(';'),\n    ...rows.map((row) => [row.grupo, row.host, row.severity, row.status, row.problem, row.age, row.time, row.recovery_time || ''].map(csvEscape).join(';'))\n  ].join('\\n');\n\n  const blob = new Blob([`\\uFEFF${csv}`], { type: 'text/csv;charset=utf-8;' });\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n\n  a.href = url;\n  a.download = `incidentes-zabbix-${new Date().toISOString().slice(0, 10)}.csv`;\n  a.click();\n\n  URL.revokeObjectURL(url);\n};\n\n/* =========================================================\n   CONTADORES\n========================================================= */\n\nconst atualizarContadoresTopo = () => {\n  const contadores = hostList.reduce((acc, host) => {\n    const status = obterStatusVisualHost(host);\n\n    if (status === 'offline') acc.offline++;\n    else if (status === 'warning') acc.warning++;\n    else acc.online++;\n\n    return acc;\n  }, { online: 0, offline: 0, warning: 0 });\n\n  const definirTexto = (selector, value) => {\n    const el = qs(selector);\n    if (el) el.innerText = value;\n  };\n\n  definirTexto('#online-count', contadores.online);\n  definirTexto('#offline-count', contadores.offline);\n  definirTexto('#warning-count', contadores.warning);\n};\n\n/* =========================================================\n   MAPA DAS UNIDADES\n========================================================= */\n\nconst carregarLeaflet = () => new Promise((resolve, reject) => {\n  if (window.L) {\n    resolve();\n