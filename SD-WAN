        "onRender": "/*\n  Painel Unidades SD-WAN - OnRender\n  Versão limpa e reorganizada para manutenção.\n  Mantém os recursos atuais: cards, agrupamento, pesquisa, modal,\n  chamados GRC/JIRA, incidentes Zabbix, links externos e indicadores C/J/Z.\n*/\n\nif (!data || !data.series) return;\n\n/* =========================================================\n   ESTADO GLOBAL DO PAINEL\n========================================================= */\n\nwindow.__nocGroupMode = window.__nocGroupMode || 'none';\nwindow.__nocHostSearchTerm = window.__nocHostSearchTerm || '';\nwindow.__nocIncidentesAtuais = [];\nwindow.__nocIncidentesHistorico = [];\n\nlet incidentesZabbixAtuaisPorHost = {};\n\nwindow.__nocMapaFiltro = window.__nocMapaFiltro || 'todas';\nwindow.__nocMapaPesquisa = window.__nocMapaPesquisa || '';\n\nwindow.__nocMapaMostrarCidades = window.__nocMapaMostrarCidades || false;\nwindow.__nocMapaFiltroLink = window.__nocMapaFiltroLink || '';\nwindow.__nocMapaFiltroHorario = window.__nocMapaFiltroHorario || '';\nwindow.__nocMapaFiltroSede = window.__nocMapaFiltroSede || '';\n\n/* =========================================================\n   CONFIGURAÇÕES\n========================================================= */\n\nconst LIMITES_ZABBIX = {\n  cpuCritico: 90,\n  fortiPerdaCritica: 25,\n  fortiLatenciaCriticaMs: 150,\n  interfacePerdaCritica: 20,\n  interfaceLatenciaCriticaMs: 300\n};\n\nconst URL_GRC = 'https://webebt04.embratel.com.br/grcport2/troubleticket_v2/ticket/tkt_ticket_form.php?id_ticket=';\nconst URL_JIRA = 'https://sefapa.atlassian.net/browse/';\nconst URL_ZABBIX_EVENTO = 'http://zabbix.sefa.pa.gov.br/zabbix/tr_events.php';\n\nconst URL_LEAFLET_CSS = 'https://zabbix.sefa.pa.gov.br/zabbix/widgets/libs/leaflet/leaflet.css';\nconst URL_LEAFLET_JS = 'https://zabbix.sefa.pa.gov.br/zabbix/widgets/libs/leaflet/leaflet.js';\n\nconst URL_MAPA_PA_MUNICIPIOS_JS = 'https://zabbix.sefa.pa.gov.br/zabbix/widgets/libs/mapas/pa-municipios-completo.js';\n\n/* =========================================================\n   UTILITÁRIOS\n========================================================= */\n\nconst qs = (selector) => htmlNode.querySelector(selector);\n\nconst obterUltimoValor = (field) => {\n  if (!field?.values) return null;\n  return field.values.get\n    ? field.values.get(field.values.length - 1)\n    : field.values[field.values.length - 1];\n};\n\nconst obterValorCampoEm = (field, index) => {\n  if (!field?.values) return '';\n  return field.values.get ? field.values.get(index) : field.values[index];\n};\n\nconst obterCampoPorNome = (series, name) => {\n  const esperado = String(name).trim().toLowerCase();\n  return series?.fields?.find((field) => String(field.name || '').trim().toLowerCase() === esperado);\n};\n\nconst obterNomeCampo = (field) => String(\n  field?.config?.displayName ||\n  field?.state?.displayName ||\n  field?.name ||\n  ''\n).trim();\n\nconst escaparHtml = (value) => String(value ?? '')\n  .replace(/&/g, '&amp;')\n  .replace(/</g, '&lt;')\n  .replace(/>/g, '&gt;')\n  .replace(/\"/g, '&quot;')\n  .replace(/'/g, '&#39;');\n\nconst normalizarTexto = (value) => String(value || '')\n  .normalize('NFD')\n  .replace(/[\\u0300-\\u036f]/g, '')\n  .toLowerCase();\n\nconst valorVazio = (value) => {\n  const text = String(value ?? '').trim();\n  return !text || ['N/D', 'NULL', 'UNDEFINED'].includes(text.toUpperCase());\n};\n\nconst escolherPrimeiroValor = (...values) => {\n  for (const value of values) {\n    if (!valorVazio(value)) return value;\n  }\n  return 'N/D';\n};\n\nconst paraNumero = (value) => {\n  const n = Number(String(value ?? '').replace(',', '.'));\n  return Number.isFinite(n) ? n : 0;\n};\n\nconst truncarTexto = (value, max = 140) => {\n  const text = String(value || 'N/D').trim();\n  return text.length <= max ? text : `${text.slice(0, max)}...`;\n};\n\nconst extrairEntre = (text, regex) => {\n  const match = String(text || '').match(regex);\n  return match ? match[1].trim() : null;\n};\n\nconst limparNomeHost = (host) => String(host || '')\n  .replace(/^SDW-/i, '')\n  .replace(/^S[\\s-_]*F[\\s-_]*/i, '')\n  .replace(/-/g, ' ')\n  .replace(/\\s+/g, ' ')\n  .trim();\n\nconst obterChaveRelacionamentoHost = (host) => normalizarTexto(limparNomeHost(host || ''));\n\nconst obterChaveHost = (series) =>\n  series?.fields?.[1]?.labels?.host ||\n  series?.fields?.find((field) => field?.labels?.host)?.labels?.host ||\n  series?.name?.split(':')[0]?.trim() ||\n  null;\n\nconst obterValorTextoSerie = (series) => {\n  const field =\n    series?.fields?.find((f) => f.type === 'string') ||\n    series?.fields?.find((f) => f.type !== 'time' && f.type !== 'number');\n\n  const value = obterUltimoValor(field);\n  return value == null ? '' : String(value);\n};\n\nconst formatarBits = (bits) => {\n  const n = Number(bits);\n  if (!n || n <= 0) return '0 bps';\n\n  const base = 1000;\n  const unidades = ['bps', 'Kbps', 'Mbps', 'Gbps', 'Tbps'];\n  const indice = Math.min(Math.floor(Math.log(n) / Math.log(base)), unidades.length - 1);\n\n  return `${parseFloat((n / Math.pow(base, indice)).toFixed(1))} ${unidades[indice]}`;\n};\n\nconst formatarUptime = (seconds) => {\n  const total = Number(seconds);\n  if (!Number.isFinite(total) || total <= 0) return '0min';\n\n  const dias = Math.floor(total / 86400);\n  const horas = Math.floor((total % 86400) / 3600);\n  const minutos = Math.floor((total % 3600) / 60);\n\n  if (dias > 0) return `${dias}d ${horas}h`;\n  if (horas > 0) return `${String(horas).padStart(2, '0')}:${String(minutos).padStart(2, '0')}`;\n  return `${minutos}min`;\n};\n\nconst obterClasseTextoCompacto = (texto, tipo = 'normal') => {\n  const len = String(texto || '').trim().length;\n\n  if (tipo === 'banda') {\n    if (len >= 11) return 'txt-compact-3';\n    if (len >= 9) return 'txt-compact-2';\n    if (len >= 7) return 'txt-compact-1';\n  }\n\n  if (tipo === 'latencia') {\n    if (len >= 7) return 'txt-compact-2';\n    if (len >= 6) return 'txt-compact-1';\n  }\n\n  return '';\n};\n\n/* =========================================================\n   REGRAS VISUAIS / LIMITES DO TEMPLATE ZABBIX\n========================================================= */\n\nconst healthCheckNormal = (link) => String(link.healthState ?? '0') === '0';\n\nconst perdaInterfaceCritica = (link) => (\n  String(link.status).toUpperCase() === 'UP' &&\n  healthCheckNormal(link) &&\n  paraNumero(link.perda) > LIMITES_ZABBIX.interfacePerdaCritica\n);\n\nconst latenciaInterfaceCritica = (link) => (\n  String(link.status).toUpperCase() === 'UP' &&\n  healthCheckNormal(link) &&\n  paraNumero(link.latencia) > LIMITES_ZABBIX.interfaceLatenciaCriticaMs\n);\n\nconst perdaFortigateCritica = (value) => {\n  const perda = paraNumero(value);\n  return perda > LIMITES_ZABBIX.fortiPerdaCritica && perda < 100;\n};\n\nconst statusVisualDoLink = (link) => {\n  const statusOperacionalDown = String(link.status).toUpperCase() === 'DOWN';\n  const healthIndisponivel = !healthCheckNormal(link);\n  const perdaTotal = paraNumero(link.perda) >= 100;\n\n  return (statusOperacionalDown || healthIndisponivel || perdaTotal) ? 'DOWN' : 'UP';\n};\n\nconst latenciaFortigateCritica = (value) => paraNumero(value) > LIMITES_ZABBIX.fortiLatenciaCriticaMs;\nconst cpuCritica = (value) => paraNumero(value) > LIMITES_ZABBIX.cpuCritico;\n\n/* =========================================================\n   NORMALIZAÇÃO DE LINKS / HOSTS\n========================================================= */\n\nconst normalizarNomeLink = (raw) => {\n  if (!raw) return 'LINK';\n\n  const text = String(raw).trim().replace(/:$/, '');\n  const match = text.match(/^([^()]+)\\(([^()]+)\\)$/);\n  if (!match) return text;\n\n  const iface = match[1].trim();\n  const aliasOriginal = match[2].trim().replace(/:$/, '');\n  const aliasUpper = aliasOriginal.toUpperCase();\n\n  let operadora = aliasOriginal;\n  if (aliasUpper.includes('PRODEPA')) operadora = 'PRODEPA';\n  else if (aliasUpper.includes('STARLINK')) operadora = 'STARLINK';\n  else if (aliasUpper.includes('CLARO')) operadora = 'CLARO';\n\n  return `${iface}(${operadora})`;\n};\n\nconst extrairNomeLinkDaSerie = (seriesName) => {\n  const raw = String(seriesName || '');\n  const label =\n    extrairEntre(raw, /Interface\\s+(.*?)\\s+Status operacional/i) ||\n    extrairEntre(raw, /Interface\\s+(.*?)\\s+Perda de Pacote/i) ||\n    extrairEntre(raw, /Interface\\s+(.*?)\\s+Perda de pacote/i) ||\n    extrairEntre(raw, /Interface\\s+(.*?)\\s+Lat[eê]ncia/i) ||\n    extrairEntre(raw, /Interface\\s+(.*?)\\s+Bits Enviados/i) ||\n    extrairEntre(raw, /Interface\\s+(.*?)\\s+Integridade do Link/i);\n\n  return label ? normalizarNomeLink(label) : null;\n};\n\nconst obterPesoInterface = (name) => {\n  const n = normalizarTexto(name);\n  if (n.startsWith('wan')) return 1;\n  if (n.startsWith('lan1')) return 2;\n  if (n.startsWith('lan2')) return 3;\n  if (n.startsWith('lan3')) return 4;\n  if (n.startsWith('lan4')) return 5;\n  if (n.startsWith('vlan')) return 6;\n  return 9;\n};\n\nconst obterPesoOperadora = (name) => {\n  const n = String(name || '').toUpperCase();\n  if (n.includes('CLARO')) return 1;\n  if (n.includes('PRODEPA')) return 2;\n  if (n.includes('STARLINK')) return 3;\n  return 9;\n};\n\nconst obterClasseSpan = (linksCount) => {\n  if (linksCount > 4) return 'span-3';\n  if (linksCount > 2) return 'span-2';\n  return '';\n};\n\n/* =========================================================\n   MODELOS DE DADOS\n========================================================= */\n\nconst criarHost = (hostKey) => ({\n  hostKey,\n  host: limparNomeHost(hostKey),\n  links: {},\n  snmpDisponibilidade: 1,\n  uptime: '0',\n  fortiLt: 0,\n  fortiPd: 0,\n  cpu: 0,\n  horarioFuncionamento: 'N/D',\n  pertenceA: 'N/D',\n  enderecoCompleto: 'N/D',\n  coordenadas: 'N/D',\n  contatos: 'N/D',\n  centroGrc: 'N/D',\n  designacaoLink: 'N/D'\n});\n\nconst criarLink = (name) => ({\n  name,\n  status: 'DOWN',\n  banda: '0 bps',\n  perda: 0,\n  latencia: 0,\n  healthState: 0\n});\n\nconst garantirHost = (hosts, hostKey) => {\n  if (!hosts[hostKey]) hosts[hostKey] = criarHost(hostKey);\n  return hosts[hostKey];\n};\n\nconst garantirLink = (hostObj, linkName) => {\n  if (!hostObj.links[linkName]) hostObj.links[linkName] = criarLink(linkName);\n  return hostObj.links[linkName];\n};\n\n/* =========================================================\n   EXTRAÇÃO DE CHAMADOS GRC / JIRA\n========================================================= */\n\nconst nomesCampos = (series) => (series.fields || []).map((f) => String(f.name || '').toLowerCase());\n\nconst serieEhGRC = (series) => {\n  const names = nomesCampos(series);\n  return names.includes('ticket') && names.includes('centro') &&\n    (names.includes('designação') || names.includes('designacao')) &&\n    names.includes('sintoma');\n};\n\nconst serieEhJira = (series) => {\n  const names = nomesCampos(series);\n  const formatoJira = names.includes('ticket') && names.includes('centro') &&\n    names.includes('tipo') && names.includes('posicionamento') &&\n    (names.includes('abertura') || names.includes('created')) &&\n    (names.includes('atualização/fechamento') || names.includes('atualizacao/fechamento') || names.includes('updated'));\n\n  return formatoJira && !serieEhGRC(series);\n};\n\nconst extrairChamadosGRC = (seriesList) => {\n  const series = seriesList.find(serieEhGRC);\n  if (!series) return [];\n\n  const fields = {\n    ticket: obterCampoPorNome(series, 'Ticket'),\n    centro: obterCampoPorNome(series, 'Centro'),\n    designacao: obterCampoPorNome(series, 'Designação') || obterCampoPorNome(series, 'Designacao'),\n    abertura: obterCampoPorNome(series, 'Data/Hora Abertura') || obterCampoPorNome(series, 'Abertura'),\n    atualizacao: obterCampoPorNome(series, 'Data/Hora Atualização/Fechamento') || obterCampoPorNome(series, 'Data/Hora Atualizacao/Fechamento') || obterCampoPorNome(series, 'Atualização/Fechamento'),\n    sintoma: obterCampoPorNome(series, 'Sintoma'