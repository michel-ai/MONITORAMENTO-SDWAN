: host.designacaoLink && host.designacaoLink !== 'N/D' ? normalizarNomeLink(`wan(${host.designacaoLink})`) : 'wan(N/D)',\n      status: 'DOWN'\n    }];\n\n    return linksOffline.map(renderizarLinkDown).join('');\n  }\n\n  if (!links.length) {\n    return `\n      <div class=\"link-block\">\n        <div class=\"link-title\">INSTABILIDADE DE COLETA</div>\n        <div class=\"link-stats\">\n          <div class=\"m-box\">\n            <span class=\"m-lbl\">STATUS</span>\n            <span class=\"m-val muted\">N/D</span>\n          </div>\n        </div>\n      </div>\n    `;\n  }\n\n  return links.map((link) =>\n    statusVisualDoLink(link) === 'DOWN'\n      ? renderizarLinkDown(link)\n      : renderizarLinkNormal(link)\n  ).join('');\n};\n\nconst obterResumoLinksHost = (host) => {\n  const links = host.linksArray || [];\n\n  const total = links.length;\n  const down = links.filter((link) => statusVisualDoLink(link) === 'DOWN').length;\n  const up = links.filter((link) => statusVisualDoLink(link) === 'UP').length;\n\n  return { total, down, up };\n};\n\nconst obterStatusVisualHost = (host) => {\n  const { total, down, up } = obterResumoLinksHost(host);\n\n  const snmpOffline = Number(host.snmpDisponibilidade) !== 1;\n\n  /*\n    OFFLINE:\n    - SNMP indisponível; ou\n    - possui links descobertos e todos estão DOWN.\n  */\n  if (snmpOffline || (total > 0 && down === total)) {\n    return 'offline';\n  }\n\n  /*\n    ATENÇÃO:\n    - possui pelo menos um link DOWN, mas ainda existe link UP.\n  */\n  if (down > 0 && up > 0) {\n    return 'warning';\n  }\n\n  return 'online';\n};\n\nconst hostEstaOfflineVisual = (host) => obterStatusVisualHost(host) === 'offline';\n\nconst renderizarCard = (host, idx) => {\n  const links = host.linksArray || [];\n  const statusClass = obterStatusVisualHost(host);\n  const isHostOffline = statusClass === 'offline';\n  const temLinkDown = statusClass === 'warning';\n\n  const cardClass = [\n    obterClasseSpan(links.length),\n    statusClass === 'offline' ? 'is-offline' : '',\n    statusClass === 'warning' ? 'is-warning' : ''\n  ].filter(Boolean).join(' ');\n\n  const cpuClass = cpuCritica(host.cpu) ? 'critical' : '';\n  const ltClass = latenciaFortigateCritica(host.fortiLt) ? 'critical' : '';\n  const pdClass = perdaFortigateCritica(host.fortiPd) ? 'critical' : '';\n\n  return `\n    <div class=\"eq-card ${cardClass}\" data-host-index=\"${idx}\">\n      <div class=\"card-header\">\n        <div class=\"card-header-content\">\n          <div class=\"card-name\">${escaparHtml(host.host)}</div>\n          ${montarIndicadoresDoCard(host, idx)}\n          <div class=\"card-grupo\">Expediente: ${escaparHtml(host.horarioFuncionamento || 'N/D')}</div>\n        </div>\n      </div>\n\n      <div class=\"equip-health ${isHostOffline ? 'equip-health-offline' : ''}\">\n        <div class=\"health-state ${statusClass === 'online' ? '' : statusClass}\">\n          ${isHostOffline ? 'OFFLINE' : 'ONLINE'}\n        </div>\n\n        ${!isHostOffline ? `\n          <div class=\"hw-item\"><span class=\"mini-tag\">Up: ${escaparHtml(host.uptime)}</span></div>\n          <div class=\"hw-item\">\n            <svg class=\"hw-icon\" viewBox=\"0 0 24 24\">\n              <path d=\"M17 17H7V7H17V17M19 19H5V5H19V19M13 3V1H11V3H9V1H7V3H5V5H3V7H1V9H3V11H1V13H3V15H1V17H3V19H5V21H7V23H9V21H11V23H13V21H15V23H17V21H19V19H21V17H23V15H21V13H23V11H21V9H23V7H21V5H19V3H17V1H15V3H13Z\" />\n            </svg>\n            <span class=\"${cpuClass}\">${escaparHtml(host.cpu)}%</span>\n          </div>\n          <div class=\"hw-item\"><span class=\"mini-tag ${ltClass}\">Lt: ${escaparHtml(host.fortiLt)} ms</span></div>\n          <div class=\"hw-item\"><span class=\"mini-tag ${pdClass}\">Pd: ${escaparHtml(host.fortiPd)}%</span></div>\n        ` : ''}\n      </div>\n\n      <div class=\"card-div\"></div>\n      <div class=\"links-wrap\">${montarLinksDoCard(host, isHostOffline)}</div>\n    </div>\n  `;\n};\n\nconst ajustarTitulosDosCards = (