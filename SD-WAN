,\n    inset 0 -1px 0 rgba(0,0,0,0.28),\n    0 8px 18px rgba(0,0,0,0.20);\n  backdrop-filter: blur(8px);\n  -webkit-backdrop-filter: blur(8px);\n}\n\n.m-box {\n  display: flex;\n  flex: 1;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  min-width: 0;\n  min-height: 46px;\n  overflow: hidden;\n  padding: 5px 4px;\n  text-align: center;\n}\n\n.m-lbl {\n  display: block;\n  width: 100%;\n  height: 11px;\n  margin-bottom: 7px;\n  overflow: hidden;\n  color: rgba(230,235,240,0.56);\n  font-size: 9px;\n  font-weight: 700;\n  line-height: 11px;\n  letter-spacing: .06em;\n  text-align: center;\n  white-space: nowrap;\n}\n\n.m-val,\n.m-sub {\n  display: block;\n  width: 100%;\n  min-height: 20px;\n  line-height: 12px;\n  text-align: center;\n}\n\n.m-val {\n  color: #f0f0f0;\n  font-size: 14px;\n  font-weight: 800;\n}\n\n.m-sub {\n  color: #00bfff;\n  font-size: 11px;\n  font-weight: 900;\n  text-shadow: none;\n}\n\n.m-val.high { color: #00ff88; }\n.m-val.mid { color: #ffc13d; }\n.m-val.low { color: #ff4f5e; }\n.m-val.muted { color: rgba(220,220,220,0.44); }\n\n.m-nowrap {\n  display: block;\n  width: 100%;\n  overflow: hidden;\n  line-height: 12px;\n  white-space: nowrap;\n  text-overflow: clip;\n}\n\n.txt-compact-1 { font-size: 11px !important; }\n.txt-compact-2 { font-size: 10px !important; }\n.txt-compact-3 { font-size: 9px !important; }\n\n.m-box-banda,\n.m-box-latencia {\n  min-width: 0;\n  overflow: hidden;\n}\n\n.link-stats-down {\n  justify-content: center;\n}\n\n.link-stats-down .offline-link-status {\n  width: 74px;\n  min-width: 74px;\n}\n\n/* =========================================================\n   CARD MAIOR\n========================================================= */\n\n.eq-card.span-2 { grid-column: span 2; }\n.eq-card.span-3 { grid-column: span 3; }\n\n.eq-card.span-2 .card-header,\n.eq-card.span-3 .card-header,\n.eq-card.span-2 .card-name,\n.eq-card.span-3 .card-name,\n.eq-card.span-2 .card-grupo,\n.eq-card.span-3 .car