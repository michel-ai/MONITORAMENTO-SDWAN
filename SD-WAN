        "html": "<div class=\"noc-root\">\n  <div class=\"topbar\">\n    <div class=\"topbar-brand\">\n      <img class=\"brand-logo\" src=\"https://zabbix.sefa.pa.gov.br/zabbix/widgets/Marca/logo_sefa_portal.png\" alt=\"Logo Governo do Pará\" />\n      <div class=\"brand-text\">\n        <span class=\"brand-title\">UNIDADES SD-WAN</span>\n        <span class=\"brand-sub\">Tempo Real</span>\n      </div>\n    </div>\n\n    <div class=\"topbar-controls\">\n      <div class=\"topbar-search-host\" id=\"host-search-box\">\n        <label class=\"host-search-label\" for=\"host-search-input\">\n          <span class=\"host-search-icon\">🔍</span>\n          Pesquisar\n        </label>\n        <div class=\"host-search-field-wrap\">\n          <input id=\"host-search-input\" class=\"host-search-input\" type=\"text\" placeholder=\"Unidade ou designação...\" autocomplete=\"off\" />\n          <button id=\"host-search-clear\" class=\"host-search-clear\" type=\"button\" title=\"Limpar pesquisa\">×</button>\n        </div>\n      </div>\n\n      <div class=\"topbar-grouping\">\n        <label class=\"grouping-label\" for=\"group-mode\">Agrupamento</label>\n        <select id=\"group-mode\" class=\"grouping-select\">\n          <option value=\"none\">Sem</option>\n          <option value=\"schedule\">Horário de Funcionamento</option>\n          <option value=\"sede\">Sede</option>\n        </select>\n      </div>\n    </div>\n\n    <div class=\"topbar-metrics\">\n      <div class=\"top-m-item top-m-card\">\n        <span class=\"t-m-dot green\">◉</span>\n        <div class=\"t-m-text\">\n          <span class=\"t-m-val\" id=\"online-count\">0</span>\n          <span class=\"t-m-lbl\">OPERANTE</span>\n        </div>\n      </div>\n\n      <div class=\"top-m-item top-m-card\">\n        <span class=\"t-m-dot red\">◉</span>\n        <div class=\"t-m-text\">\n          <span class=\"t-m-val\" id=\"offline-count\">0</span>\n          <span class=\"t-m-lbl\">OFFLINE</span>\n        </div>\n      </div>\n\n      <div class=\"top-m-item top-m-card\">\n        <span class=\"t-m-dot orange\">◉</span>\n        <div class=\"t-m-text\">\n          <span class=\"t-m-val\" id=\"warning-count\">0</span>\n          <span class=\"t-m-lbl\">ATENÇÃO</span>\n        </div>\n      </div>\n\n      <div class=\"topbar-metrics-separator\"></div>\n\n      <button id=\"incidents-toggle\" class=\"top-m-item top-m-card top-alert-card top-alert-z\" type=\"button\" title=\"Incidentes Zabbix\">\n        <span class=\"top-alert-letter\">Z</span>\n        <div class=\"t-m-text\"><span class=\"t-m-val\" id=\"zabbix-alert-count\">0</span></div>\n      </button>\n\n      <button id=\"tickets-toggle-jira\" class=\"top-m-item top-m-card top-alert-card top-alert-j\" type=\"button\" title=\"Chamados JIRA\">\n        <span class=\"top-alert-letter\">J</span>\n        <div class=\"t-m-text\"><span class=\"t-m-val\" id=\"tickets-toggle-count-jira\">0</span></div>\n      </button>\n\n      <button id=\"tickets-toggle\" class=\"top-m-item top-m-card top-alert-card top-alert-c\" type=\"button\" title=\"Chamados Claro GRC\">\n        <span class=\"top-alert-letter\">C</span>\n        <div class=\"t-m-text\"><span class=\"t-m-val\" id=\"tickets-toggle-count\">0</span></div>\n      </button>\n    </div>\n\n    <div class=\"topbar-right\">\n      <button id=\"mapa-toggle\" class=\"topbar-map-btn\" type=\"button\" title=\"Mapa das unidades\">\n        🗺️\n      </button>\n\n      <div class=\"topbar-clock\" id=\"clock\">--:--:--</div>\n    </div>\n  </div>\n\n  <div class=\"noc-body\">\n    <main class=\"cards-area\">\n      <div id=\"cards-root\"></div>\n    </main>\n  </div>\n\n  <div id=\"modal-overlay\" class=\"modal-overlay\">\n    <div class=\"modal-content\">\n      <span class=\"modal-close\" id=\"modal-close\">&times;</span>\n      <div class=\"modal-header\">\n        <div id=\"modal-title\" class=\"modal-title\">Detalhes do Dispositivo</div>\n      </div>\n      <div id=\"modal-body\" class=\"modal-body\"></div>\n    </div>\n  </div>\n\n  <div id=\"tickets-drawer\" class=\"tickets-drawer\">\n    <div class=\"tickets-drawer-header\">\n      <div class=\"tickets-drawer-title\">\n        <span class=\"sidebar-title-icon sidebar-title-icon-c\">C</span>\n        Chamados Claro GRC - SD-WAN\n      </div>\n      <div class=\"tickets-drawer-actions\">\n        <span id=\"tickets-count-label\" class=\"tickets-count-label\">0 chamado(s)</span>\n        <button id=\"tickets-close\" class=\"tickets-close\" type=\"button\">Fechar</button>\n      </div>\n    </div>\n    <div id=\"tickets-drawer-body\" class=\"tickets-drawer-body\">\n      <div class=\"tickets-empty\">Sem chamados abertos</div>\n    </div>\n  </div>\n\n  <div id=\"tickets-drawer-jira\" class=\"tickets-drawer\">\n    <div class=\"tickets-drawer-header\">\n      <div class=\"tickets-drawer-title\">\n        <span class=\"sidebar-title-icon sidebar-title-icon-j\">J</span>\n        Chamados JIRA - SD-WAN\n      </div>\n      <div class=\"tickets-drawer-actions\">\n        <span id=\"tickets-count-label-jira\" class=\"tickets-count-label\">0 chamado(s)</span>\n        <button id=\"tickets-close-jira\" class=\"tickets-close\" type=\"button\">Fechar</button>\n      </div>\n    </div>\n    <div id=\"tickets-drawer-body-jira\" class=\"tickets-drawer-body\">\n      <div class=\"tickets-empty\">Sem chamados abertos</div>\n    </div>\n  </div>\n\n  <div id=\"incidents-sidebar\" class=\"incidents-sidebar\">\n    <div class=\"incidents-sidebar-header\">\n      <div class=\"incidents-sidebar-title\">\n        <span class=\"sidebar-title-icon sidebar-title-icon-z\">Z</span>\n        Incidentes Zabbix\n      </div>\n      <div class=\"incidents-sidebar-actions\">\n        <input id=\"incidents-search\" class=\"incidents-search\" type=\"text\" placeholder=\"Pesquisar unidade...\" />\n        <button id=\"incidents-csv\" class=\"incidents-close\" type=\"button\">CSV</button>\n        <button id=\"incidents-close\" class=\"incidents-close\" type=\"button\">Fechar</button>\n      </div>\n    </div>\n\n    <div class=\"incidents-sidebar-body\">\n      <section class=\"inc-section inc-section-open\">\n        <div class=\"inc-section-header\">\n          <span class=\"inc-section-title\">Incidentes no momento</span>\n          <span id=\"inc-open-count\" class=\"inc-section-count\">0</span>\n        </div>\n        <div id=\"inc-open-body\" class=\"inc-table-wrap\"><div class=\"tickets-empty\">Sem incidentes</div></div>\n      </section>\n\n      <section class=\"inc-section inc-section-history\">\n        <div class=\"inc-section-header\">\n          <span class=\"inc-section-title\">Incidentes Resolvidos (15 dias)</span>\n          <span id=\"inc-history-count\" class=\"inc-section-count\">0</span>\n        </div>\n        <div id=\"inc-history-body\" class=\"inc-table-wrap\"><div class=\"tickets-empty\">Sem incidentes</div></div>\n      </section>\n    </div>\n  </div>\n  \n  <div id=\"mapa-sidebar\" class=\"incidents-sidebar mapa-sidebar\">\n    <div class=\"incidents-sidebar-header\">\n      <div class=\"incidents-sidebar-title\">\n        <span class=\"sidebar-title-icon sidebar-title-icon-map\">🗺</span>\n        Mapa das Unidades\n      </div>\n\n      <div class=\"incidents-sidebar-actions\">\n        <button id=\"mapa-close\" class=\"incidents-close\" type=\"button\">Fechar</button>\n      </div>\n    </div>\n\n    <div class=\"incidents-sidebar-body mapa-sidebar-body\">\n      <div class=\"mapa-toolbar\">\n        <div class=\"mapa-filtros\">\n          <button type=\"button\" class=\"mapa-filter active\" data-map-filter=\"todas\">Todas</button>\n          <button type=\"button\" class=\"mapa-filter\" data-map-filter=\"operante\">Online</button>\n          <button type=\"button\" class=\"mapa-filter\" data-map-filter=\"offline\">Offline</button>\n          <button type=\"button\" class=\"mapa-filter\" data-map-filter=\"atencao\">Atenção</button>\n        </div>\n\n        <div class=\"mapa-search-wrap\">\n          <input\n            id=\"mapa-search\"\n            class=\"mapa-search\"\n            type=\"text\"\n            placeholder=\"Buscar unidade ou designação...\"\n            autocomplete=\"off\"\n          >\n          <button id=\"mapa-search-clear\" class=\"mapa-search-clear\" type=\"button\" title=\"Limpar pesquisa\">×</button>\n        </div>\n      </div>\n\n      <div id=\"mapa-unidades\"></div>\n    </div>\n  </div>\n</div>\n",
        "onInit": "// Sets the text from customProperties\nconst htmlgraphicsText = htmlNode.getElementById('htmlgraphics-text');\n\nif (htmlgraphicsText) {\n  htmlgraphicsText.textContent = customProperties.text;\n\n  // Change the text color based on the theme\n  if (theme.isDark) {\n    htmlgraphicsText.style.color = 'green';\n  } else {\n    htmlgraphicsText.style.color = 'red';\n  }\n}\n",
